# Get these from https://my.telegram.org -> API Development Tools
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# Comma-separated channel usernames (without @) or numeric IDs
TELEGRAM_CHANNELS=-1001234567890

# LiteLLM proxy (runs in docker-compose, no auth needed for localhost)
LLM_API_KEY=sk-placeholder
LLM_API_URL=http://localhost:4000/v1/chat/completions
LLM_MODEL=gpt-5

# LiteLLM backend — your actual LLM provider (any OpenAI-compatible API)
LLM_BACKEND_API_BASE=https://api.example.com/v1/
LLM_BACKEND_API_KEY=your_provider_api_key

# Alerts & interactive bot — create your own bot via @BotFather, get your chat ID from @userinfobot
ALERT_BOT_TOKEN=your_bot_token_from_botfather
ALERT_CHAT_ID=your_telegram_user_id

# Investment budget (USD)
BUDGET_MIN=10000
BUDGET_MAX=15000

# Output
OUTPUT_FILE=extracted.jsonl
MEDIA_DIR=media

# InfluxDB (telemetry)
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=shares-telemetry-token
INFLUXDB_ORG=shares
INFLUXDB_BUCKET=telemetry
